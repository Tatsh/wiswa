{
  "permissions": {
    "allow": [
      "Read(.vscode/dictionary.txt)",
      "Read(.wiswa-ci/**)",
      "Read(~/.cache/mypy/**)",
      "Read(~/.cache/uv/**)",
      "Shell(gh api)",
      "Shell(mkdir --parents .wiswa-ci)",
      "Shell(mkdir -p .wiswa-ci)",
      "Shell(mkdir .wiswa-ci)",
      "Shell(mktemp)",
      "Shell(uv add)",
      "Shell(uv audit)",
      "Shell(uv cache)",
      "Shell(uv export)",
      "Shell(uv lock)",
      "Shell(uv pip)",
      "Shell(uv remove)",
      "Shell(uv run mypy)",
      "Shell(uv run pytest)",
      "Shell(uv run ruff)",
      "Shell(uv run sphinx-build)",
      "Shell(uv run ty)",
      "Shell(uv run wiswa)",
      "Shell(uv run yapf)",
      "Shell(uv run yarn pyright)",
      "Shell(uv sync)",
      "Shell(uv tree)",
      "Shell(uv venv)",
      "Shell(uv version)",
      "Shell(yarn check-formatting)",
      "Shell(yarn check-spelling)",
      "Shell(yarn cspell)",
      "Shell(yarn dict:update)",
      "Shell(yarn format)",
      "Shell(yarn gen-docs)",
      "Shell(yarn gen-manpage)",
      "Shell(yarn markdownlint-cli2)",
      "Shell(yarn mypy)",
      "Shell(yarn prettier)",
      "Shell(yarn pyright)",
      "Shell(yarn qa)",
      "Shell(yarn regen)",
      "Shell(yarn ruff)",
      "Shell(yarn ruff:fix)",
      "Shell(yarn test)",
      "Shell(yarn test:cov)",
      "WebFetch(api.github.com)",
      "WebFetch(npmjs.com)",
      "WebFetch(pypi.org)",
      "WebFetch(readthedocs.io)",
      "Write(.vscode/dictionary.txt)",
      "Write(.wiswa-ci/**)",
      "Write(~/.cache/mypy/**)",
      "Write(~/.cache/uv/**)"
    ],
    "deny": []
  }
}
