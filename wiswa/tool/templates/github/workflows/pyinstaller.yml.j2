{% from 'github/workflows/pyinstaller-build.sh.j2' import build %}
{% from 'github/workflows/pyinstaller-test.ps1.j2' import test_powershell %}
{% from 'github/workflows/pyinstaller-test.sh.j2' import test_bash %}
{% set win_sv = settings.github.secret_vars.windows %}
{% set apple_sv = settings.github.secret_vars.apple %}
jobs:
  build:
    env:
{% if settings.supported_platforms == 'all' or 'windows' in settings.supported_platforms %}
      WINDOWS_SIGNING_CERT: ${{ '{{' }} secrets.{{ win_sv.signing_certificate }} }}
{% endif %}
{% if settings.supported_platforms == 'all' or 'macos' in settings.supported_platforms %}
      APPLE_SIGNING_CERT: ${{ '{{' }} secrets.{{ apple_sv.signing_certificate }} }}
{% endif %}
    runs-on: ${{ '{{' }} matrix.os }}
    steps:
      - uses: 'actions/checkout@{{ github_latest_action_sha('actions', 'checkout') }}'
        with:
          persist-credentials: false
{% if settings.package_manager == 'uv' %}
      - name: 'Install yq'
        run: 'pipx install yq'
      - name: 'Install uv'
        uses: 'astral-sh/setup-uv@{{ github_latest_action_sha('astral-sh', 'setup-uv') }}'
        with:
          enable-cache: false
{% else %}
      - name: 'Install Poetry'
        run: 'pipx install poetry yq'
{% endif %}
      - name: 'Set up Python'
        uses: 'actions/setup-python@{{ github_latest_action_sha('actions', 'setup-python') }}'
        with:
{% if settings.package_manager != 'uv' %}
          cache: 'poetry'
{% endif %}
          python-version: '3.13'
{% if settings.pyinstaller.vcpkg.enabled %}
  {% for os_name, target in settings.pyinstaller.vcpkg.targets.items() %}
      - if: matrix.os == '{{ os_name }}'
        name: 'Cache vcpkg installed packages'
        uses: 'actions/cache@{{ github_latest_action_sha('actions', 'cache') }}'
        with:
          key: vcpkg-{{ target.triplet }}-{{ target.packages | join('-') }}-${{ '{{' }} hashFiles('.github/workflows/pyinstaller.yml') }}
          path: '~/vcpkg/installed'
      - if: matrix.os == '{{ os_name }}'
        name: 'Set up vcpkg'
        run: |
          $cachedInstalled = $null
          if (Test-Path "$env:USERPROFILE\vcpkg\installed") {
            $cachedInstalled = "$env:TEMP\vcpkg-installed"
            Move-Item "$env:USERPROFILE\vcpkg\installed" $cachedInstalled
            Remove-Item -Recurse -Force "$env:USERPROFILE\vcpkg"
          }
          git clone --depth 1 https://github.com/microsoft/vcpkg "$env:USERPROFILE\vcpkg"
          if ($cachedInstalled) {
            Move-Item $cachedInstalled "$env:USERPROFILE\vcpkg\installed"
          }
          & "$env:USERPROFILE\vcpkg\bootstrap-vcpkg.bat" -disableMetrics
    {% for pkg in target.packages %}
          & "$env:USERPROFILE\vcpkg\vcpkg.exe" install {{ pkg }} --triplet {{ target.triplet }}
    {% endfor %}

          $installed = "$env:USERPROFILE\vcpkg\installed\{{ target.triplet }}"

          Add-Content -Path $env:GITHUB_PATH -Value "$env:USERPROFILE\vcpkg"
          Add-Content -Path $env:GITHUB_PATH -Value "$installed\tools\pkgconf"
          Add-Content -Path $env:GITHUB_ENV -Value "VCPKG_ROOT=$env:USERPROFILE\vcpkg"
          Add-Content -Path $env:GITHUB_ENV -Value "VCPKG_DEFAULT_TRIPLET={{ target.triplet }}"
          Add-Content -Path $env:GITHUB_ENV -Value "OPENSSL_DIR=$installed"
          $sep = [IO.Path]::PathSeparator
          Add-Content -Path $env:GITHUB_ENV -Value "PKG_CONFIG_PATH=$installed\lib\pkgconfig$sep$env:PKG_CONFIG_PATH"
          Add-Content -Path $env:GITHUB_ENV -Value "CMAKE_PREFIX_PATH=$installed$sep$env:CMAKE_PREFIX_PATH"
          Add-Content -Path $env:GITHUB_ENV -Value "LIB=$installed\lib$sep$env:LIB"
          Add-Content -Path $env:GITHUB_ENV -Value "INCLUDE=$installed\include$sep$env:INCLUDE"
        shell: 'pwsh'
  {% endfor %}
{% endif %}
{% if settings.package_manager == 'uv' %}
      - name: 'Install dependencies (uv)'
        run: |
          uv sync{{ ' ' + settings.pyinstaller.uv_sync_args | join(' ') if settings.pyinstaller.uv_sync_args else '' }}
          uv pip install pyinstaller
        shell: 'bash'
{% else %}
      - name: 'Install dependencies (Poetry)'
        run: |
          poetry install
          poetry run -- pip install pyinstaller
        shell: 'bash'
{% endif %}
      - name: 'Build with PyInstaller'
        run: |
          {{ build(settings) | indent(10) | trim }}
        shell: 'bash'
{% if settings.supported_platforms == 'all' or 'windows' in settings.supported_platforms %}
      - if: (matrix.os == 'windows-latest' || matrix.os == 'windows-11-arm') && env.WINDOWS_SIGNING_CERT != ''
        name: 'Sign Windows binaries'
        env:
          SIGNING_CERT_BASE64: ${{ '{{' }} secrets.{{ win_sv.signing_certificate }} }}
          SIGNING_PASSWORD: ${{ '{{' }} secrets.{{ win_sv.signing_password }} }}
          TIMESTAMP_URL: ${{ '{{' }} secrets.{{ win_sv.timestamp_url }} }}
        run: |
          $certBytes = [Convert]::FromBase64String($env:SIGNING_CERT_BASE64)
          $certPath = Join-Path $env:RUNNER_TEMP 'cert.pfx'
          [IO.File]::WriteAllBytes($certPath, $certBytes)
          $timestampArgs = @()
          if ($env:TIMESTAMP_URL) {
            $timestampArgs = @('/tr', $env:TIMESTAMP_URL, '/td', 'sha256')
          }
          foreach ($exe in (Get-ChildItem -Path dist\*.exe)) {
            Write-Host "Signing '$($exe.Name)'..."
            & signtool sign /f $certPath /p $env:SIGNING_PASSWORD @timestampArgs /fd sha256 $exe.FullName
            if ($LASTEXITCODE -ne 0) { throw "signtool failed for $($exe.Name)" }
          }
          Remove-Item $certPath
        shell: 'pwsh'
      - if: matrix.os == 'windows-latest' || matrix.os == 'windows-11-arm'
        name: 'Test binary'
        run: |
          {{ test_powershell(settings.pyinstaller.test_commands) | indent(10) | trim }}
{% endif %}
{% if settings.supported_platforms == 'all' or 'macos' in settings.supported_platforms %}
      - if: (matrix.os == 'macos-latest' || matrix.os == 'macos-15-intel') && env.APPLE_SIGNING_CERT != ''
        name: 'Sign and notarise macOS binaries'
        env:
          APPLE_CERT_BASE64: ${{ '{{' }} secrets.{{ apple_sv.signing_certificate }} }}
          APPLE_CERT_PASSWORD: ${{ '{{' }} secrets.{{ apple_sv.signing_password }} }}
          APPLE_IDENTITY: ${{ '{{' }} secrets.{{ apple_sv.signing_identity }} }}
          APPLE_ID_EMAIL: ${{ '{{' }} secrets.{{ apple_sv.apple_id }} }}
          APPLE_ID_PASSWORD: ${{ '{{' }} secrets.{{ apple_sv.app_specific_password }} }}
          APPLE_TEAM: ${{ '{{' }} secrets.{{ apple_sv.team_id }} }}
        run: |
          keychain="$RUNNER_TEMP/signing.keychain-db"
          cert_path="$RUNNER_TEMP/cert.p12"
          base64 -d <<<"$APPLE_CERT_BASE64" > "$cert_path"
          security create-keychain -p '' "$keychain"
          security set-keychain-settings "$keychain"
          security unlock-keychain -p '' "$keychain"
          security import "$cert_path" -k "$keychain" -P "$APPLE_CERT_PASSWORD" \
            -T /usr/bin/codesign -T /usr/bin/security
          security set-key-partition-list -S 'apple-tool:,apple:' -k '' "$keychain"
          security list-keychains -d user -s "$keychain" login.keychain-db
          for file in dist/*; do
            if [[ "${file}" == dist/index.*js ]]; then
              continue
            fi
            echo "Signing '${file}'..."
            codesign --force --options runtime --sign "$APPLE_IDENTITY" --timestamp "$file"
          done
          zip_path="$RUNNER_TEMP/notarize.zip"
          zip -j "$zip_path" dist/*
          xcrun notarytool submit "$zip_path" \
            --apple-id "$APPLE_ID_EMAIL" \
            --password "$APPLE_ID_PASSWORD" \
            --team-id "$APPLE_TEAM" \
            --wait
          for file in dist/*; do
            if [[ "${file}" == dist/index.*js ]]; then
              continue
            fi
            xcrun stapler staple "$file" || true
          done
          rm -f "$cert_path" "$zip_path"
          security delete-keychain "$keychain"
        shell: 'bash'
      - if: matrix.os == 'macos-latest' || matrix.os == 'macos-15-intel'
        name: 'Test binary'
        run: |
          {{ test_bash(settings.pyinstaller.test_commands) | indent(10) | trim }}
{% endif %}
      - name: 'Upload Artifacts'
        uses: 'actions/upload-artifact@{{ github_latest_action_sha('actions', 'upload-artifact') }}'
        with:
          if-no-files-found: error
          name: {{ settings.github_project_name }}-binaries-${{ '{{' }} matrix.suffix }}
          path: |
            ${{ '{{' }} matrix.dist_path }}
  {% if not settings.private %}
      - name: 'Attest'
        uses: 'actions/attest@{{ github_latest_action_sha('actions', 'attest') }}'
        with:
          subject-path: '${{ '{{' }} matrix.dist_path }}'
      - name: 'Generate SBOM'
        uses: 'anchore/sbom-action@{{ github_latest_action_sha('anchore', 'sbom-action') }}'
        env:
          SYFT_SOURCE_NAME: '{{ settings.github_project_name }}'
          SYFT_SOURCE_VERSION: ${{ '{{' }} github.ref_name }}
        with:
          path: 'dist/'
          output-file: 'sbom.spdx.json'
          upload-artifact: false
      - name: 'Attest SBOM'
        uses: 'actions/attest@{{ github_latest_action_sha('actions', 'attest') }}'
        with:
          subject-path: '${{ '{{' }} matrix.dist_path }}'
          sbom-path: 'sbom.spdx.json'
  {% endif %}
{% if settings.supported_platforms == 'all' or 'macos' in settings.supported_platforms %}
      - if: (matrix.os == 'macos-latest' || matrix.os == 'macos-15-intel') && github.ref_type == 'tag'
        name: 'Zip files'
        env:
          DIST_PATH: ${{ '{{' }} matrix.dist_path }}
          REF_NAME: ${{ '{{' }} github.ref_name }}
          SUFFIX: ${{ '{{' }} matrix.suffix }}
        run: |
          rm -fR _out
          mkdir _out
          zip -j "_out/{{ settings.github_project_name }}-${REF_NAME}-${SUFFIX}.zip" "$DIST_PATH"
{% endif %}
{% if settings.supported_platforms == 'all' or 'windows' in settings.supported_platforms %}
      - if: (matrix.os == 'windows-latest' || matrix.os == 'windows-11-arm') && github.ref_type == 'tag'
        name: 'Zip files'
        env:
          DIST_PATH: ${{ '{{' }} matrix.dist_path }}
          REF_NAME: ${{ '{{' }} github.ref_name }}
          SUFFIX: ${{ '{{' }} matrix.suffix }}
        run: |
          Remove-Item -Force _out -ErrorAction Continue
          New-Item -ItemType Directory -Name _out
          Compress-Archive -Path $env:DIST_PATH -DestinationPath "_out/{{ settings.github_project_name }}-$env:REF_NAME-$env:SUFFIX.zip"
        shell: pwsh
{% endif %}
  {% if not settings.private %}
      - if: github.ref_type == 'tag'
        name: 'Attest'
        uses: 'actions/attest@{{ github_latest_action_sha('actions', 'attest') }}'
        with:
          subject-path: '_out/*.zip'
      - if: github.ref_type == 'tag'
        name: 'Attest SBOM'
        uses: 'actions/attest@{{ github_latest_action_sha('actions', 'attest') }}'
        with:
          subject-path: '_out/*.zip'
          sbom-path: 'sbom.spdx.json'
  {% endif %}
      - if: github.ref_type == 'tag'
        name: Create or update draft release
        env:
          GH_TOKEN: ${{ '{{' }} github.token }}
        run: |
          gh release create "$GITHUB_REF_NAME" --draft --notes '' _out/*.zip ||
            gh release upload "$GITHUB_REF_NAME" _out/*.zip --clobber
    strategy:
      matrix:
        include:
{% if settings.supported_platforms == 'all' or 'macos' in settings.supported_platforms %}
          - os: 'macos-15-intel'
            dist_path: 'dist/*'
            suffix: 'mac-x86_64'
          - os: 'macos-latest'
            dist_path: 'dist/*'
            suffix: 'mac-arm64'
{% endif %}
{% if settings.supported_platforms == 'all' or 'windows' in settings.supported_platforms %}
          - os: 'windows-latest'
            dist_path: 'dist/*.exe'
            suffix: 'win-x86_64'
  {% if not settings.private %}
          - os: 'windows-11-arm'
            dist_path: 'dist/*.exe'
            suffix: 'win-arm64'
  {% endif %}
{% endif %}
name: 'PyInstaller'
'on':
  push:
    branches:
      - 'master'
    paths:
{% for mod in settings.modules %}
      - '{{ mod | replace('.', '/') }}/**'
{% endfor %}
      - '.github/workflows/pyinstaller.yml'
      - 'pyproject.toml'
      - 'uv.lock'
      - 'poetry.lock'
    tags:
      - 'v*.*.*'
permissions:
{% if settings.private %}
  actions: 'write'
{% endif %}
  attestations: 'write'
  contents: 'write'
  id-token: 'write'
