.. only:: html

   .. image:: https://img.shields.io/pypi/pyversions/{{ settings.project_name }}.svg?color=blue&logo=python&logoColor=white
      :target: https://www.python.org/
      :alt: Python versions

   .. image:: https://img.shields.io/pypi/v/{{ settings.project_name }}
      :target: https://pypi.org/project/{{ settings.project_name }}/
      :alt: PyPI - Version

{% if settings.using_github %}
   .. image:: https://img.shields.io/github/v/tag/{{ settings.github.username }}/{{ settings.project_name }}
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/tags
      :alt: GitHub tag (with filter)

   .. image:: https://img.shields.io/github/license/{{ settings.github.username }}/{{ settings.project_name }}
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/blob/master/LICENSE.txt
      :alt: License

   .. image:: https://img.shields.io/github/commits-since/{{ settings.github.username }}/{{ settings.project_name }}/v{{ settings.version }}/master
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/compare/v{{ settings.version }}...master
      :alt: GitHub commits since latest release (by SemVer including pre-releases)

   .. image:: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/actions/workflows/codeql.yml/badge.svg
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/actions/workflows/codeql.yml
      :alt: CodeQL

   .. image:: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/actions/workflows/qa.yml/badge.svg
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/actions/workflows/qa.yml
      :alt: QA

   .. image:: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/actions/workflows/tests.yml/badge.svg
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/actions/workflows/tests.yml
      :alt: Tests

   .. image:: https://coveralls.io/repos/github/{{ settings.github.username }}/{{ settings.project_name }}/badge.svg?branch=master
      :target: https://coveralls.io/github/{{ settings.github.username }}/{{ settings.project_name }}?branch=master
      :alt: Coverage Status
{% endif %}

   .. image:: https://readthedocs.org/projects/{{ settings.project_name }}/badge/?version=latest
      :target: https://{{ settings.project_name }}.readthedocs.org/?badge=latest
      :alt: Documentation Status

   .. image:: https://www.mypy-lang.org/static/mypy_badge.svg
      :target: https://mypy-lang.org/
      :alt: mypy

   .. image:: https://img.shields.io/badge/pre--commit-enabled-brightgreen?logo=pre-commit&logoColor=white
      :target: https://github.com/pre-commit/pre-commit
      :alt: pre-commit

   .. image:: https://img.shields.io/badge/pydocstyle-enabled-AD4CD3
      :target: https://www.pydocstyle.org/en/stable/
      :alt: pydocstyle

{% if settings.want_tests %}
   .. image:: https://img.shields.io/badge/pytest-zz?logo=Pytest&labelColor=black&color=black
      :target: https://docs.pytest.org/en/stable/
      :alt: pytest
{% endif %}

   .. image:: https://img.shields.io/endpoint?url=https://raw.githubusercontent.com/astral-sh/ruff/main/assets/badge/v2.json
      :target: https://github.com/astral-sh/ruff
      :alt: Ruff

   .. image:: https://static.pepy.tech/badge/{{ settings.project_name }}/month
      :target: https://pepy.tech/project/{{ settings.project_name }}
      :alt: Downloads

   .. image:: https://img.shields.io/github/stars/{{ settings.github.username }}/{{ settings.project_name }}?logo=github&style=flat
      :target: https://github.com/{{ settings.github.username }}/{{ settings.project_name }}/stargazers
      :alt: Stargazers

{% for badge in settings.custom_project_badges | sort(attribute='priority') %}
{% set parsed = badge.anchor | parse_md_badge %}
{% if parsed.image %}
   .. image:: {{ parsed.image }}
      :target: {{ badge.href }}
      :alt: {{ parsed.alt }}

{% endif %}
{% endfor %}
   .. image:: https://img.shields.io/badge/dynamic/json?url=https%3A%2F%2Fpublic.api.bsky.app%2Fxrpc%2Fapp.bsky.actor.getProfile%2F%3Factor%3Ddid%3Aplc%3Auq42idtvuccnmtl57nsucz72%26query%3D%24.followersCount%26style%3Dsocial%26logo%3Dbluesky%26label%3DFollow%2520%40{{ settings.github.username }}&query=%24.followersCount&style=social&logo=bluesky&label=Follow%20%40{{ settings.github.username }}
      :target: https://bsky.app/profile/{{ settings.github.username }}.bsky.social
      :alt: Follow @{{ settings.github.username }}

{% if settings.social and settings.social.mastodon and settings.social.mastodon.id and settings.social.mastodon.domain %}
   .. image:: https://img.shields.io/mastodon/follow/{{ settings.social.mastodon.id }}?domain={{ settings.social.mastodon.domain }}&style=social
      :target: https://{{ settings.social.mastodon.domain }}/@{{ settings.github.username }}
      :alt: Mastodon Follow
{% endif %}
