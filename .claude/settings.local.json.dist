{
  "env": {
    "MYPY_CACHE_DIR": ".wiswa-ci/cache/mypy",
    "RUFF_CACHE_DIR": ".wiswa-ci/cache/ruff",
    "UV_CACHE_DIR": ".wiswa-ci/cache/uv",
    "YARN_CACHE_FOLDER": ".wiswa-ci/cache/yarn"
  },
  "permissions": {
    "allow": [
      "Bash(gh api *)",
      "Bash(mkdir --parents .wiswa-ci)",
      "Bash(mkdir -p .wiswa-ci)",
      "Bash(mkdir .wiswa-ci)",
      "Bash(mktemp *)",
      "Bash(uv add *)",
      "Bash(uv audit *)",
      "Bash(uv cache *)",
      "Bash(uv export *)",
      "Bash(uv lock *)",
      "Bash(uv pip *)",
      "Bash(uv remove *)",
      "Bash(uv run mypy *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run sphinx-build *)",
      "Bash(uv run ty *)",
      "Bash(uv run wiswa *)",
      "Bash(uv run yapf *)",
      "Bash(uv run yarn pyright *)",
      "Bash(uv sync *)",
      "Bash(uv tree *)",
      "Bash(uv venv *)",
      "Bash(uv version *)",
      "Bash(yarn check-formatting *)",
      "Bash(yarn check-spelling *)",
      "Bash(yarn cspell *)",
      "Bash(yarn dict:update *)",
      "Bash(yarn format *)",
      "Bash(yarn gen-docs *)",
      "Bash(yarn gen-manpage *)",
      "Bash(yarn markdownlint-cli2 *)",
      "Bash(yarn mypy *)",
      "Bash(yarn prettier *)",
      "Bash(yarn pyright *)",
      "Bash(yarn qa *)",
      "Bash(yarn regen *)",
      "Bash(yarn ruff *)",
      "Bash(yarn ruff:fix *)",
      "Bash(yarn test *)",
      "Bash(yarn test:cov *)",
      "Edit(/.vscode/dictionary.txt)",
      "Edit(/.wiswa-ci/**)",
      "Read(/.vscode/dictionary.txt)",
      "Read(/.wiswa-ci/**)",
      "Update(/.vscode/dictionary.txt)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:readthedocs.io)"
    ]
  }
}
