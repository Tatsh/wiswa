function(settings)
  {
    packages: settings.packages,
    dependencies: {
      python: '>=3.%s,<3.14' % settings.min_python_minor_version,
    } + settings.dependencies.main,
    group: {
      dev: {
        optional: true,
        dependencies: settings.dependencies.dev,
      },
      docs: {
        optional: true,
        dependencies: settings.dependencies.docs,
      },
      tests: {
        optional: true,
        dependencies: settings.dependencies.tests,
      },
    },
  }
