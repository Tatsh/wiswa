{
  hooks: [
    {
      id: 'poetry-check',
      stages: [
        'pre-push',
      ],
    },
    {
      id: 'poetry-lock',
      stages: [
        'pre-push',
      ],
    },
    {
      args: [
        '--all-extras',
        '--all-groups',
        '--sync',
      ],
      id: 'poetry-install',
    },
  ],
  repo: 'https://github.com/python-poetry/poetry',
  rev: '2.1.1',
}
