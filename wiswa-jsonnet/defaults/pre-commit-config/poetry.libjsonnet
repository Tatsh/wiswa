{
  hooks: [
    {
      id: 'poetry-check',
      stages: [
        'pre-push',
      ],
    },
    {
      id: 'poetry-lock',
      stages: [
        'pre-push',
      ],
    },
    {
      args: [
        '--all-groups',
      ],
      id: 'poetry-install',
    },
  ],
  repo: 'https://github.com/python-poetry/poetry',
  rev: std.native('githubLatestReleaseTag')('python-poetry', 'poetry'),
}
