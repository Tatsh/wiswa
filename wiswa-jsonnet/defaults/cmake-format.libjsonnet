/**
  * @file defaults/cmake-format.libjsonnet
  * @namespace cmake_format
  * @brief Default configuration for CMake format.
 */
{
  /** @brief Get CMake format configuration.
   * @param line_width Maximum line width for formatted CMake files.
   * @returns An object representing the CMake format configuration.
   * @pt int
   * @rv object
   */
  get(line_width=100):: {
    format: {
      autosort: true,
      line_width: line_width,
    },
  },
}
