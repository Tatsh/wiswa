{
  local interval = 'weekly',
  updates: [
    {
      directory: '/',
      'package-ecosystem': 'npm',
      schedule: {
        interval: interval,
      },
    },
    {
      directory: '/',
      'package-ecosystem': 'pip',
      schedule: {
        interval: interval,
      },
    },
    {
      directory: '/',
      'package-ecosystem': 'github-actions',
      schedule: {
        interval: interval,
      },
    },
  ],
  version: 2,
}
