/**
 * @file luacheckrc.libsonnet
 * @namespace luacheckrc
 * @brief Default configuration for Luacheck.
 */
{
  /** @brief Maximum allowed length for code lines. */
  max_code_line_length: 100,
  /** @brief Maximum allowed length for comment lines. */
  max_comment_line_length: 100,
  /** @brief Maximum allowed length for any line. */
  max_line_length: 100,
  /** @brief Maximum allowed length for string lines. */
  max_string_line_length: 100,
}
