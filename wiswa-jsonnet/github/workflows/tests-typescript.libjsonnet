function(settings)
  {
    jobs: {
      test: {
        'runs-on': settings.tests_run_on,
        steps: [
          {
            uses: 'actions/checkout@v5',
          },
          {
            name: 'Install dependencies (Yarn)',
            run: 'yarn',
          },
          {
            name: 'Tests',
            run: 'yarn jest --coverage',
          },
          {
            name: 'Coveralls',
            uses: 'coverallsapp/github-action@v2',
          },
        ],
      },
    },
    name: 'Tests',
    on: {
      pull_request: {
        branches: [
          settings.default_branch,
        ],
      },
      push: {
        branches: [
          settings.default_branch,
        ],
      },
    },
    permissions: {
      contents: 'read',
    },
  }
